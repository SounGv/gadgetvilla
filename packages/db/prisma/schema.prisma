// ============================================================
// GADGET VILLA — Prisma Schema (PostgreSQL)
// Phase 3: Database Design — ครบทุก module, production-ready
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// AUTH / RBAC
// ---------------------------------------------------------
enum Role {
  GUEST
  CUSTOMER
  DEALER
  STAFF
  CONTENT_EDITOR
  WAREHOUSE
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  firstName     String?
  lastName      String?
  phone         String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  avatarUrl     String?

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  questions     Question[]
  wishlist      WishlistItem[]
  carts         Cart[]
  warranties    WarrantyRegistration[]
  tickets       Ticket[]
  refreshTokens RefreshToken[]
  oauthAccounts OAuthAccount[]
  auditLogs     AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

model OAuthAccount {
  id             String @id @default(cuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String // google
  providerUserId String
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  line1      String
  line2      String?
  subdistrict String?
  district   String?
  province   String
  postalCode String
  isDefault  Boolean @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------
// CATALOG: Brand / Category / Product / Variant
// ---------------------------------------------------------
model Brand {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  logoUrl     String?
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  imageUrl  String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  ProductCategory[]
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([parentId])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  shortDesc     String?
  description   String?   @db.Text
  warranty      String?
  brandId       String
  brand         Brand     @relation(fields: [brandId], references: [id])
  status        ProductStatus @default(DRAFT)

  // SEO
  metaTitle     String?
  metaDesc      String?

  isFeatured    Boolean   @default(false)
  isNewArrival  Boolean   @default(false)

  categories    ProductCategory[]
  variants      ProductVariant[]
  images        ProductImage[]
  specs         ProductSpec[]
  features      ProductFeature[]
  downloads     ProductDownload[]
  reviews       Review[]
  questions     Question[]
  wishlist      WishlistItem[]
  relatedFrom   ProductRelation[] @relation("related_source")
  relatedTo     ProductRelation[] @relation("related_target")

  // BigSeller sync
  bigsellerId   String?   @unique

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([brandId])
  @@index([status])
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String   @unique
  barcode      String?
  name         String   // เช่น "Black / 65W"
  price        Decimal  @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  cost         Decimal? @db.Decimal(12, 2)
  weightGram   Int?
  options      Json?    // { color: "Black", power: "65W" }
  imageUrl     String?
  inventory    Inventory[]
  orderItems   OrderItem[]
  cartItems    CartItem[]
  bigsellerSku String?  @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  type      String  @default("image") // image | video | view360
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  group     String? // เช่น "Connectivity"
  key       String
  value     String
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductFeature {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  imageUrl  String?
  sortOrder Int     @default(0)

  @@index([productId])
}

model ProductDownload {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  type      String  // driver | firmware | manual | software
  fileUrl   String
  version   String?
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductRelation {
  id         String  @id @default(cuid())
  sourceId   String
  targetId   String
  type       String  // related | crosssell | upsell
  source     Product @relation("related_source", fields: [sourceId], references: [id], onDelete: Cascade)
  target     Product @relation("related_target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([targetId])
}

// ---------------------------------------------------------
// INVENTORY / WAREHOUSE
// ---------------------------------------------------------
model Warehouse {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  address   String?
  isActive  Boolean     @default(true)
  inventory Inventory[]
  createdAt DateTime    @default(now())
}

model Inventory {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  quantity    Int            @default(0)
  reserved    Int            @default(0)
  updatedAt   DateTime       @updatedAt

  @@unique([variantId, warehouseId])
  @@index([warehouseId])
}

// ---------------------------------------------------------
// CART
// ---------------------------------------------------------
model Cart {
  id        String     @id @default(cuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?    // guest cart
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int            @default(1)

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ---------------------------------------------------------
// ORDER / PAYMENT / SHIPPING
// ---------------------------------------------------------
enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id             String       @id @default(cuid())
  orderNo        String       @unique
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  status         OrderStatus  @default(PENDING)

  // amounts
  subtotal       Decimal      @db.Decimal(12, 2)
  discountTotal  Decimal      @db.Decimal(12, 2) @default(0)
  shippingFee    Decimal      @db.Decimal(12, 2) @default(0)
  taxTotal       Decimal      @db.Decimal(12, 2) @default(0)
  grandTotal     Decimal      @db.Decimal(12, 2)

  couponCode     String?

  // snapshot address
  shipName       String
  shipPhone      String
  shipAddress    Json

  wantTaxInvoice Boolean      @default(false)
  taxInfo        Json?

  items          OrderItem[]
  payment        Payment?
  shipment       Shipment?
  invoices       Invoice[]
  returns        ReturnRequest[]

  // integration sync
  bigsellerOrderId String?    @unique
  trcloudRef       String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id         String         @id @default(cuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  // snapshot
  productName String
  sku        String
  unitPrice  Decimal        @db.Decimal(12, 2)
  quantity   Int
  lineTotal  Decimal        @db.Decimal(12, 2)

  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PROMPTPAY
  CREDIT_CARD
  MOBILE_BANKING
  COD
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String        // omise | 2c2p | gbprimepay
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("THB")
  transactionId String?       // charge id จาก gateway
  rawPayload    Json?         // webhook payload
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

model Shipment {
  id           String         @id @default(cuid())
  orderId      String         @unique
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier      String         // flash | jt | kerry | thaipost | dhl
  trackingNo   String?
  status       ShipmentStatus @default(PENDING)
  labelUrl     String?
  cost         Decimal?       @db.Decimal(12, 2)
  shippedAt    DateTime?
  deliveredAt  DateTime?
  events       Json?          // tracking timeline
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// ---------------------------------------------------------
// INVOICE (เอกสาร)
// ---------------------------------------------------------
enum InvoiceType {
  QUOTATION
  TAX_INVOICE
  RECEIPT
  DELIVERY_NOTE
  CREDIT_NOTE
}

model Invoice {
  id         String      @id @default(cuid())
  orderId    String
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type       InvoiceType
  docNo      String      @unique
  pdfUrl     String?
  trcloudRef String?
  issuedAt   DateTime    @default(now())

  @@index([orderId])
}

// ---------------------------------------------------------
// PROMOTION / COUPON
// ---------------------------------------------------------
enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  type        DiscountType
  value       Decimal      @db.Decimal(12, 2)
  minSpend    Decimal?     @db.Decimal(12, 2)
  maxDiscount Decimal?     @db.Decimal(12, 2)
  usageLimit  Int?
  usedCount   Int          @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
}

enum PromotionKind {
  FLASH_SALE
  BUNDLE
  CAMPAIGN
}

model Promotion {
  id        String        @id @default(cuid())
  kind      PromotionKind
  title     String
  config    Json          // rules: product ids, discount, bundle items
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  @@index([kind])
}

// ---------------------------------------------------------
// REVIEW / Q&A / WISHLIST
// ---------------------------------------------------------
model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int      // 1-5
  title      String?
  body       String?
  images     Json?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@unique([productId, userId])
}

model Question {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  answer    String?
  answeredAt DateTime?
  createdAt DateTime @default(now())

  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ---------------------------------------------------------
// AFTER-SALES: Warranty / Return / Ticket
// ---------------------------------------------------------
model WarrantyRegistration {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sku          String
  serialNo     String?
  purchaseDate DateTime
  proofUrl     String?
  months       Int      @default(12)
  status       String   @default("active")
  createdAt    DateTime @default(now())

  @@index([userId])
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
  EXCHANGED
}

model ReturnRequest {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String       // return | exchange
  reason    String
  status    ReturnStatus @default(REQUESTED)
  images    Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([orderId])
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

model Ticket {
  id        String         @id @default(cuid())
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  subject   String
  category  String?
  status    TicketStatus   @default(OPEN)
  messages  TicketMessage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  body      String
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ---------------------------------------------------------
// CONTENT: Blog / FAQ
// ---------------------------------------------------------
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  body        String    @db.Text
  coverUrl    String?
  authorName  String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FaqItem {
  id        String  @id @default(cuid())
  category  String?
  question  String
  answer    String  @db.Text
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

// ---------------------------------------------------------
// INTEGRATION / SYSTEM
// ---------------------------------------------------------
model SyncLog {
  id        String   @id @default(cuid())
  source    String   // bigseller | trcloud
  entity    String   // product | order | inventory | invoice
  direction String   // inbound | outbound
  status    String   // success | failed
  refId     String?
  message   String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([source, entity])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // create | update | delete
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
