# ============================================================
# GADGET VILLA — Environment Variables (คัดลอกเป็น .env แล้วกรอกค่าจริง)
# ห้าม commit ไฟล์ .env ขึ้น git — ใส่ค่า secret จริงในเครื่อง/เซิร์ฟเวอร์เท่านั้น
# ============================================================

# ---- Core ----
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---- Database ----
POSTGRES_USER=gadgetvilla
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=gadgetvilla
DATABASE_URL=postgresql://gadgetvilla:change_me_strong_password@localhost:5432/gadgetvilla?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth / JWT ----
JWT_ACCESS_SECRET=generate_a_long_random_string
JWT_REFRESH_SECRET=generate_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- Google OAuth (สร้างที่ Google Cloud Console) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ---- Payment Gateway (default: Omise) ----
PAYMENT_PROVIDER=omise
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=
OMISE_WEBHOOK_SECRET=

# ---- Shipping Carriers (กรอกเฉพาะเจ้าที่ใช้) ----
FLASH_API_KEY=
JT_API_KEY=
KERRY_API_KEY=
THAIPOST_API_KEY=
DHL_API_KEY=

# ---- BigSeller ----
BIGSELLER_API_KEY=
BIGSELLER_API_SECRET=
BIGSELLER_WEBHOOK_SECRET=

# ---- TRCLOUD ----
TRCLOUD_API_KEY=
TRCLOUD_COMPANY_ID=

# ---- Chat / Notify ----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
MESSENGER_PAGE_TOKEN=
TELEGRAM_BOT_TOKEN=

# ---- Email (transactional) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="GADGET VILLA <no-reply@gadgetvilla.co.th>"

# ---- Observability (optional) ----
SENTRY_DSN=

# ---- Cloudflare Tunnel (จาก Zero Trust → Networks → Tunnels) ----
CLOUDFLARE_TUNNEL_TOKEN=
